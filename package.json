{
  "name": "agentic-builder",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered desktop application built with Next.js and Electron",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:b": "PORT=${PORT:-3001} NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-b} next dev --turbopack --port ${PORT:-3001}",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron:dev": "concurrently --kill-others-on-fail --prefix \"[{time}]\" --timestamp-format \"yyyy-MM-dd HH:mm:ss\" \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:dev:b": "PORT=${PORT:-3001} NEXT_DIST_DIR=${NEXT_DIST_DIR:-.next-b} concurrently --kill-others-on-fail --prefix \"[{time}]\" --timestamp-format \"yyyy-MM-dd HH:mm:ss\" \"npm run dev:b\" \"wait-on http://localhost:${PORT:-3001} && BUILDER_DEV_URL=http://localhost:${PORT:-3001} BUILDER_INSTANCE_LABEL=B electron . --user-data-dir=$HOME/.agentic-builder-electron-b\"",
    "electron:build": "npm run build && electron-builder",
    "electron:pack": "npm run build && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest",
    "memory": "tsx scripts/memory-cli.ts",
    "memory:list": "tsx scripts/memory-cli.ts list",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-sql": "tsx src/lib/db/migrate.ts",
    "db:setup": "tsx src/lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "memory:show": "tsx scripts/memory-cli.ts show",
    "memory:search": "tsx scripts/memory-cli.ts search",
    "memory:recall": "tsx scripts/memory-cli.ts recall",
    "memory:stats": "tsx scripts/memory-cli.ts stats",
    "memory:trace": "tsx scripts/memory-cli.ts trace",
    "memory:invalidate-classification": "tsx scripts/memory-cli.ts invalidate-classification",
    "memory:mine-patterns": "tsx scripts/memory-mine-patterns.ts",
    "memory:approve": "tsx scripts/memory-cli.ts approve",
    "memory:disapprove": "tsx scripts/memory-cli.ts disapprove",
    "memory:attribute": "tsx scripts/memory-attribute.ts",
    "memory:ab-compare": "tsx scripts/memory-ab-compare.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.38",
    "@langchain/langgraph": "^1.2.9",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "langfuse": "^3.38.6",
    "lucide-react": "^1.12.0",
    "marked": "^18.0.2",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "proper-lockfile": "^4.1.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.4"
  }
}
