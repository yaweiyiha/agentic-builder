# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres connection string. Required.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app

# Enable PG SSL (only set "true" for managed cloud DBs that require it).
DB_SSL=false

# ─── Migration runner ─────────────────────────────────────────────────────────
# When set to "1" (default), `initDb()` runs every pending migration under
# `src/database/migrations/` on backend startup via umzug. Set to "0" for
# production deploys where migrations should be applied as an explicit
# release step via `pnpm migrate`.
AUTO_MIGRATE=1

# ─── TimescaleDB (optional) ───────────────────────────────────────────────────
# Set to 1 if your Postgres does NOT have the TimescaleDB extension
# installed — this is the common case for Homebrew, dev Docker images,
# GitHub Actions runners, and most cloud preview DBs.
#
# When disabled: migrations that would create hypertables fall back to
# plain Postgres tables. Queries still work, you just lose Timescale's
# perf optimisations for time-series scans.
#
# Recommendation: keep TIMESCALE_DISABLED=1 for local dev. Flip to 0 (or
# unset) only when you have Timescale installed AND you intentionally
# want the perf benefit.
TIMESCALE_DISABLED=1

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── JWT auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=replace-me-with-a-32-byte-random-string
JWT_EXPIRES_IN=24h
