{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.12.4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:compile": "pnpm exec concurrently \"tsc -b --watch --preserveWatchOutput\" \"vite build --watch\" \"vite\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "e2e": "playwright install chromium --with-deps && playwright test",
    "e2e:headed": "playwright install chromium --with-deps && playwright test --headed"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "@privy-io/react-auth": "^3.22.1",
    "antd": "^6.3.5",
    "axios": "^1.7.7",
    "dayjs": "^1.11.13",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "pnpm": {
    "overrides": {
      "secure-password-utilities": "0.2.1-beta.1"
    }
  }
}
