# dependencies
/node_modules
# scaffold templates must stay source-only; local installs break copyScaffold
scaffolds/**/node_modules
generated-code/node_modules/
generated-code/dist/
generated-code/public/design/*.png

# generated-code: keep huge/generated trees local; commit pipeline diagnostics only
generated-code/*
!generated-code/.ralph/
!generated-code/.ralph/**
!generated-code/.agentic-snapshot/
!generated-code/.agentic-snapshot/**
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

*.zip

# next.js
/.next/
/out/

# electron
/dist/

# env files
.env
.env.local
.env*.local

# testing
/coverage

# pipeline snapshot (debug-only, may contain large doc content)
.blueprint/pipeline-snapshot.json
.blueprint/design-references/

# memory system L1 — only per-developer / cache files. records/** holds
# the committable knowledge (classifications, failure patterns, decisions,
# scaffold-fitness, agent-tuning) and survives across machines via git.
# See design doc §4.
.memory/metrics.json
.memory/metrics.json.tmp
.memory/.lock-target
.memory/.lock-target.lock
.memory/trace.jsonl
.memory/store.sqlite

# misc
*.pem
.DS_Store
*.tsbuildinfo
next-env.d.ts

worklog-automation
