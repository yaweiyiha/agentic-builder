{
  "name": "pomodoro-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @pomodoro/api\" \"npm run dev -w @pomodoro/web\"",
    "dev:web": "npm run dev -w @pomodoro/web",
    "dev:api": "npm run dev -w @pomodoro/api",
    "build": "npm run build -w @pomodoro/shared-types && npm run build -w @pomodoro/api && npm run build -w @pomodoro/web"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@pomodoro/shared-types": "^0.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "react-router-dom": "^7.14.0",
    "vitest": "^4.1.3"
  }
}
