extend schema
  @link(url: "https://specs.apollo.dev/federation/v2.3", import: ["@key", "@shareable"])

type Query {
  product(id: ID!): Product
  products(limit: Int = 20, offset: Int = 0, vendorId: ID, categoryId: ID): [Product!]!
  category(id: ID!): Category
  categories: [Category!]!
}

type Mutation {
  createProduct(input: CreateProductInput!): Product!
  updateProduct(id: ID!, input: UpdateProductInput!): Product!
  deleteProduct(id: ID!): Boolean!
  
  createCategory(input: CreateCategoryInput!): Category!
  updateCategory(id: ID!, input: UpdateCategoryInput!): Category!
}

type Product @key(fields: "id") {
  id: ID!
  vendorId: ID!
  name: String!
  description: String
  sku: String!
  basePrice: Float!
  currency: String!
  categories: [Category!]!
  variants: [Variant!]!
  pricingTiers: [PricingTier!]!
  attributes: [Attribute!]!
  isActive: Boolean!
  createdAt: String!
  updatedAt: String!
}

type Category @key(fields: "id") {
  id: ID!
  name: String!
  slug: String!
  parentId: ID
  children: [Category!]!
}

type Variant {
  id: ID!
  sku: String!
  name: String!
  priceOffset: Float!
  attributes: [Attribute!]!
  inventoryQuantity: Int!
}

type PricingTier {
  id: ID!
  customerGroupId: ID
  minQuantity: Int!
  price: Float!
}

type Attribute @shareable {
  name: String!
  value: String!
}

input CreateProductInput {
  vendorId: ID!
  name: String!
  description: String
  sku: String!
  basePrice: Float!
  currency: String!
  isActive: Boolean = false
}

input UpdateProductInput {
  name: String
  description: String
  basePrice: Float
  isActive: Boolean
}

input CreateCategoryInput {
  name: String!
  slug: String!
  parentId: ID
}

input UpdateCategoryInput {
  name: String
  slug: String
  parentId: ID
}
