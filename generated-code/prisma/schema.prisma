generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  claims        Claim[] // Add this relation for claims

  // Pomodoro specific fields (from PRD/TRD)
  // These could also be in a separate UserSettings model, but for simplicity, let's put them here for now.
  // If UserSettings model is preferred, it would be:
  // settings UserSettings?
  workDurationMinutes        Int?      @default(25)
  shortBreakDurationMinutes  Int?      @default(5)
  longBreakDurationMinutes   Int?      @default(15)
  longBreakInterval          Int?      @default(4) // Number of work sessions before a long break
  notificationSoundEnabled   Boolean?  @default(true)

  // PomodoroSession relation
  pomodoroSessions PomodoroSession[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Pomodoro models (from PRD/TRD)
model PomodoroSession {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  userId         String        @db.ObjectId
  user           User          @relation(fields: [userId], references: [id])
  sessionType    SessionType
  durationMinutes Int
  startTime      DateTime
  endTime        DateTime
  status         PomodoroStatus @default(COMPLETED)
  createdAt      DateTime      @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}

enum SessionType {
  WORK
  SHORT_BREAK
  LONG_BREAK
}

enum PomodoroStatus {
  COMPLETED
  SKIPPED
  ABORTED
}

// Claim model (new for this task)
model Claim {
  id                 String      @id @default(auto()) @map("_id") @db.ObjectId
  userId             String      @db.ObjectId
  user               User        @relation(fields: [userId], references: [id])
  type               String      // e.g., 'expense', 'leave', 'issue'
  description        String
  attachmentMetadata Json?       // Store metadata about attachments, e.g., { "filename": "report.pdf", "url": "s3://..." }
  status             ClaimStatus @default(PENDING)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([userId])
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  DRAFT // Optional, for claims not yet submitted
}
