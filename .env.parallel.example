# ─── Parallel Agentic Builder dev server (project B) ────────────────────
# Source this file in a separate terminal BEFORE running `pnpm dev` to
# launch a second instance on port 3001 with its own generated-code/
# directory and its own Postgres database. Project A keeps using
# .env.local untouched.
#
# Usage:
#   cp .env.parallel.example .env.parallel   # one-time setup
#   # (edit values below if you want different paths / DBs)
#   ./scripts/start-parallel-dev.sh
#
# The script source-loads .env.parallel and runs `next dev` on PORT=3001.
# Anything not overridden here falls back to .env.local — that means LLM
# keys, MEMORY_INJECT, etc. ARE shared between A and B (acceptable; they
# are read-only in both processes).

# Next.js dev server port (default 3000 in .env.local, MUST differ).
PORT=3001

# Where this dev server writes generated-code/ for its sessions.
# Relative paths are resolved against the project root.
CODE_OUTPUT_DIR=generated-code-b

# Separate Postgres database so projects A and B don't trample each
# other's tables / migrations. Create it once with:
#
#   psql -U postgres -c "CREATE DATABASE tasks_dev_b OWNER tasks_user;"
#
BLUEPRINT_GENERATED_DATABASE_URL=postgresql://tasks_user:tasks_password@localhost:5432/tasks_dev_b
