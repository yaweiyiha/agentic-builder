# Primary LLM gateway
# Add your OpenRouter key in .env.local. The app routes LLM traffic through OpenRouter.
OPENROUTER_API_KEY=

# PRD generation only: Anthropic Messages-compatible API (e.g. internal Claude Code gateway).
# When both are set, PM Agent uses this for PRD (non-stream + stream) instead of OpenRouter MODEL_CONFIG.prd.
# ANTHROPIC_BASE_URL=https://your-gateway.example.com/api
# ANTHROPIC_AUTH_TOKEN=
# Optional: model id for the gateway (defaults to claude-sonnet-4-20250514 if unset)
# ANTHROPIC_PRD_MODEL=claude-sonnet-4-20250514
# Optional: x-api-key (default) or bearer — ANTHROPIC_AUTH_SCHEME=bearer
# Optional cap on max output tokens — ANTHROPIC_MAX_OUTPUT_TOKENS=128000

# Code generation (optional): OpenAI-compatible Chat Completions (e.g. Claude via gptsapi).
# When CODEGEN_API_KEY is set, pipeline codegen and fix steps use this instead of OpenRouter codeGen/codeFix.
# Put real secrets only in .env.local — never commit keys.
# CODEGEN_API_KEY=
# CODEGEN_OPENAI_BASE_URL=https://api.gptsapi.net/v1
# CODEGEN_MODEL=claude-opus-4-6

# Legacy direct gateways (kept only for optional low-level helpers / migration)
# They are NOT required for the main app flow.

# GPT-5.4 via ByteDance modelhub
GPT5_BASE_URL=https://aidp-i18ntt-sg.tiktok-row.net/api/modelhub/online
GPT5_API_KEY=

# SeeDream (Doubao) — Volcengine image generation for PRD wireframe sketches
# Model: doubao-seedream-5-0-260128  API: https://ark.cn-beijing.volces.com/api/v3/images/generations
# Get your key at: https://console.volcengine.com/ark
SEEDREAM_API_KEY=

# Gemini-compatible gateway (legacy / optional)
GEMINI_BASE_URL=https://geminicode.net/v1
GEMINI_API_KEY=

# Pipeline: default codegen folder (relative to project root); UI can override per machine.
CODE_OUTPUT_DIR=generated-code

# Generated-code workspace: written to generated-code/.env at coding scaffold (DATABASE_URL for Prisma).
# Use a URL-encoded password if it contains @ (e.g. p%40ssword for p@ssword).
# BLUEPRINT_GENERATED_DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# --- Project kick-off: Git / Jira (optional; webhooks OR direct API) ---
# If a webhook URL is set, it is used instead of the direct API for that integration.
#
# Webhooks (your own HTTPS endpoint; JSON body = project_kickoff payload)
# PROJECT_KICKOFF_GIT_WEBHOOK_URL=
# PROJECT_KICKOFF_JIRA_WEBHOOK_URL=
# PROJECT_KICKOFF_WEBHOOK_BEARER_TOKEN=
#
# GitHub (direct): classic PAT with "repo" scope, or fine-grained token with repo creation on your account/org
# https://github.com/settings/tokens
# GITHUB_TOKEN=
# PROJECT_KICKOFF_GITHUB_TOKEN=
# PROJECT_KICKOFF_GITHUB_ORG=
# PROJECT_KICKOFF_GITHUB_REPO=
# Same token is used to push generated-code to that repo (Kick-off tab → Push).
# After kick-off, clone URL is saved to .blueprint/kickoff-repo.json
#
# Jira: off unless explicitly enabled (task breakdown in UI is simulated without Jira)
 PROJECT_KICKOFF_JIRA_ENABLED=false
#
# Jira Cloud (direct): API token + site; create at https://id.atlassian.com/manage-profile/security/api-tokens
# PROJECT_KICKOFF_JIRA_HOST=https://your-site.atlassian.net
# PROJECT_KICKOFF_JIRA_EMAIL=
# PROJECT_KICKOFF_JIRA_API_TOKEN=
# PROJECT_KICKOFF_JIRA_PROJECT_KEY=
# PROJECT_KICKOFF_JIRA_ISSUE_TYPE=Task

# Langfuse - Observability (set LANGFUSE_ENABLED=true to activate)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Pencil desktop MCP
# PENCIL_APP_PATH=/Applications/Pencil.app
# PENCIL_MCP_INIT_TIMEOUT_MS=120000
# PENCIL_MCP_TOOL_TIMEOUT_MS=180000
# PENCIL_MCP_BATCH_TIMEOUT_MS=600000
# PENCIL_BATCH_MAX_LINES=4
# PENCIL_BATCH_PAUSE_MS=500
